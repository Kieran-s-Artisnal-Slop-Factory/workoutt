import Layout from '../layouts/Layout.astro';
import ActiveWorkoutApp from '../components/apps/ActiveWorkoutApp.svelte';
---

<Layout title="Active workout" hideFab>
  <ActiveWorkoutApp client:only="svelte" />
</Layout>
