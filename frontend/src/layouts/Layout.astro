---
import '../styles/theme.css';
import '../styles/global.css';
import Navbar from '../components/Navbar.svelte';
import FabNav from '../components/FabNav.svelte';
import WarningBanner from '../components/WarningBanner.svelte';
import { href } from '../lib/paths';

interface Props {
  title: string;
  /** Hide the floating action button (e.g. during an active workout). */
  hideFab?: boolean;
}

const { title, hideFab = false } = Astro.props;
const currentPath = Astro.url.pathname;
// Base-aware asset/SW URLs (host under a sub-path, e.g. GitHub Pages).
const iconUrl = href('/icon.svg');
const manifestUrl = href('/manifest.webmanifest');
const swUrl = href('/sw.js');
const swScope = href('/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content="Workoutt — workout tracker and planner" />
    <meta name="theme-color" content="#ff7a1a" />
    <link rel="icon" href={iconUrl} type="image/svg+xml" />
    <link rel="manifest" href={manifestUrl} />
    <title>{title} · Workoutt</title>
    <script is:inline>
      // Apply the manual theme override before first paint to avoid a flash.
      // 'light'/'dark' pin the scheme; anything else follows the OS setting.
      try {
        const theme = localStorage.getItem('workoutt-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.style.colorScheme = theme;
        }
      } catch {}
    </script>
  </head>
  <body>
    <Navbar client:load {currentPath} />
    <WarningBanner client:load />
    <script>
      // Onboarding gate: no page is usable until onboarding completes. Runs
      // on every page (MPA). A read failure means damaged storage — send the
      // user to onboarding, which offers best-effort recovery. Base-aware so
      // it works when hosted under a sub-path (e.g. GitHub Pages /workoutt/).
      import { all } from '../lib/db/repo';
      import type { UserProfile } from '../lib/db/types';
      import { href, isPath } from '../lib/paths';

      if (!isPath(location.pathname, '/onboarding/')) {
        try {
          const profile = (await all<UserProfile>('user_profile'))[0];
          if (!profile?.onboarding_completed_at) {
            location.replace(href('/onboarding/'));
          }
        } catch (err) {
          console.error('[workoutt] onboarding check failed:', err);
          location.replace(href('/onboarding/'));
        }
      }
    </script>
    <main class="page">
      <slot />
    </main>
    {!hideFab && <FabNav client:load />}
    {
      import.meta.env.PROD ? (
        <script is:inline define:vars={{ swUrl, swScope }}>
          if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
              navigator.serviceWorker.register(swUrl, { scope: swScope }).catch(() => {});
            });
          }
        </script>
      ) : (
        <script is:inline>
          // Dev: the service worker must NOT run — it caches Vite's module
          // URLs and serves stale code after edits (blank pages). Unregister
          // any leftover registration and drop its caches.
          if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then((regs) => {
              for (const reg of regs) reg.unregister();
            });
            if (window.caches) {
              caches.keys().then((keys) => keys.forEach((k) => caches.delete(k)));
            }
          }
        </script>
      )
    }
  </body>
</html>
